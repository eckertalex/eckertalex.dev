---
import SiteLogo from "./SiteLogo.astro";
import SkipNav from "./SkipNav.astro";
---

<header class="flex items-center justify-between py-4">
  <SkipNav />
  <SiteLogo />
  <nav class="flex gap-4">
    <a href="/rss.xml" class="w-9 px-0">
      <svg
        class="size-5"
        xmlns="http://www.w3.org/2000/svg"
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-rss-icon lucide-rss"
        ><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"
        ></path><circle cx="5" cy="19" r="1"></circle></svg
      >
      <span class="sr-only">RSS</span>
    </a>
  </nav>
</header>
