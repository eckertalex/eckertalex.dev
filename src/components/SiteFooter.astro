---
import { siteConfig } from "../content/siteConfig.ts";
import SiteLogo from "./SiteLogo.astro";
---

<footer class="mt-16 border-t pb-16 pt-24">
  <div class="grid grid-cols-2 gap-16 md:grid-cols-4">
    <div class="col-span-2 flex flex-col space-y-6">
      <SiteLogo />
      <p class="text-slate-500 text-xl">
        A developer who cares about the user.
      </p>
    </div>
    <div>
      <div class="scroll-m-20 text-lg font-semibold tracking-tight">
        General
      </div>
      <ul class="mt-4 flex flex-col gap-4">
        <li>
          <a
            href="/impressum"
            class="text-slate-500 ring-offset-background focus-visible:ring-ring rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            Impressum
          </a>
        </li>
        <li>
          <a
            href="/datenschutz"
            class="text-slate-500 ring-offset-background focus-visible:ring-ring rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            Datenschutz
          </a>
        </li>
        <li>
          <a
            href={siteConfig.links.github}
            class="text-slate-500 ring-offset-background focus-visible:ring-ring rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            GitHub
          </a>
        </li>
        <li>
          <a
            href={siteConfig.links.linkedin}
            class="text-slate-500 ring-offset-background focus-visible:ring-ring rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            aedIn
          </a>
        </li>
      </ul>
    </div>
    <div>
      <div class="scroll-m-20 text-lg font-semibold tracking-tight">
        Sitemap
      </div>
      <ul class="mt-4 flex flex-col gap-4">
        <li>
          <a
            href="/"
            class="text-slate-500 ring-offset-background focus-visible:ring-ring rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            Home
          </a>
        </li>
        <li>
          <a
            href="/blog"
            class="text-slate-500 ring-offset-background focus-visible:ring-ring rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            Blog
          </a>
        </li>
        <li>
          <a
            href="/about"
            class="text-slate-500 ring-offset-background focus-visible:ring-ring rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            About
          </a>
        </li>
        <li>
          <a
            href="/sitemap.xml"
            class="text-slate-500 ring-offset-background focus-visible:ring-ring rounded-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
          >
            Sitemap
          </a>
        </li>
      </ul>
    </div>
  </div>
  <p class="text-slate-500 mt-8 text-sm">
    All rights reserved © Alexander Eckert 2025
  </p>
</footer>
