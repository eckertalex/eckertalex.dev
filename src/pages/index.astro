---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div class="flex flex-col gap-12">
    <section class="mt-8 flex flex-col-reverse gap-4 md:flex-row md:items-end">
      <div class="flex flex-1 flex-col items-start gap-2">
        <h1
          class="scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl"
        >
          Hey, I'm Alexander
        </h1>
        <p class="text-muted-foreground text-xl">
          A developer who cares about the user.
        </p>
        <p class="text-muted-foreground text-xl">
          I am a software developer, father of two and husband to a wonderful
          wife.
        </p>
      </div>
    </section>
    <section>
      <div class="mb-4 flex items-center">
        <h1 class="mt-2 flex-1 scroll-m-20 text-4xl font-bold">Latest Posts</h1>
        <a href="/blog">
          <span>Read all posts</span>
        </a>
      </div>
    </section>
  </div>
</Layout>
